# --- AWS / DynamoDB ---
# Region your table lives in
AWS_REGION=ap-south-1

# Table name (see infra/dynamodb-table.yaml)
DYNAMODB_TABLE_NAME=ledger-todo

# Only needed for LOCAL development if you are not using an AWS profile / IAM role.
# In production (Vercel, Lambda, ECS, etc.) prefer an execution-role with the least-privilege
# policy in infra/iam-policy.json instead of static keys.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- App access control ---
# The app is single-tenant (personal use) and is protected by a simple password gate
# (see src/middleware.ts). Set a strong passphrase here.
APP_PASSWORD=change-me-to-something-long-and-random

# Secret used to HMAC-sign the session cookie. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=

# Session lifetime in seconds (default 7 days)
SESSION_MAX_AGE=604800
